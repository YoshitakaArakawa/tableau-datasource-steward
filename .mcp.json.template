{
  "mcpServers": {
    "tableau": {
      "command": "npx",
      "args": ["-y", "@tableau/mcp-server@latest"],
      "env": {
        "SERVER": "https://<your-tableau-server-host>",
        "SITE_NAME": "<your-site-content-url>",
        "PAT_NAME": "<your-personal-access-token-name>",
        "PAT_VALUE": "<your-personal-access-token-secret>",
        "INCLUDE_TOOLS": "datasource"
      }
    }
  }
}
